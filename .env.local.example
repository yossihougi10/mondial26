# Supabase - מהדשבורד של Supabase > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Football Data API - מ-football-data.org (הרשמה חינמית)
FOOTBALL_DATA_API_KEY=your-api-key

# האימייל של האדמין (לגישה לפאנל הניהול)
ADMIN_EMAIL=admin@example.com

# סוד לסנכרון אוטומטי דרך Vercel Cron
# צור מחרוזת אקראית ארוכה ושמור אותה פה
CRON_SECRET=your-random-secret-string
